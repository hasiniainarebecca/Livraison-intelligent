{
  "cli": {
    "version": ">= 10.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.1.X:8000/api",
        "EXPO_PUBLIC_STRIPE_PK": "pk_test_..."
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.1.X:8000/api",
        "EXPO_PUBLIC_STRIPE_PK": "pk_test_..."
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://votre-domaine.com/api",
        "EXPO_PUBLIC_STRIPE_PK": "pk_live_..."
      }
    }
  }
}
